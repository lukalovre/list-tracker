<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:vm="using:ListTracker.ViewModels" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:uc="clr-namespace:ListTracker.Views;assembly=ListTracker" xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia" mc:Ignorable="d" x:DataType="vm:StatsViewModel" x:Class="ListTracker.Views.StatsView" xmlns:view="using:ListTracker.Views">
    <DockPanel>
        <lvc:CartesianChart Series="{Binding _1001}" XAxes="{Binding _1001XAxes}"/>
    </DockPanel>
</UserControl>