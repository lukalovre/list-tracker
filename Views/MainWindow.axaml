<Window xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:vm="using:ListTracker.ViewModels" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:uc="clr-namespace:ListTracker.Views;assembly=ListTracker" mc:Ignorable="d" x:Class="ListTracker.Views.MainWindow" x:DataType="vm:MainWindowViewModel" Icon="/Assets/icon.ico" Title="list-tracker" xmlns:v="using:ListTracker.Views" x:CompileBindings="True">
    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel />
    </Design.DataContext>
    <DockPanel>
        <TabControl Margin="5">
            <TabItem Header="Main">
                <TabControl TabStripPlacement="Left">
                    <TabItem Header="Movies">
                        <v:MoviesView DataContext="{Binding MoviesViewModel}" />
                    </TabItem>
                    <TabItem Header="Games">
                        <v:GamesView DataContext="{Binding GamesViewModel}" />
                    </TabItem>
                    <TabItem Header="TV Shows">
                        <v:TVShowsView DataContext="{Binding TVShowsViewModel}" />
                    </TabItem>
                </TabControl>
            </TabItem>
            <TabItem Header="Stats">
                <v:StatsView DataContext="{Binding StatsViewModel}" />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>